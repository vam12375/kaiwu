# Kaiwu 后端环境变量模板
# 复制此文件为 .env.local 并填入真实密钥

# Public URL used in generated project file/image links.
# Production example: PUBLIC_BASE_URL=https://your-domain.example
PUBLIC_BASE_URL=http://localhost:5001

# DeepSeek API（对话生成）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 豆包 Seed API（对话 + 报告生成）
DOUBAO_API_KEY=ark-your-doubao-key-here

# 火山方舟 Seedream API（文生图）
SEEDREAM_API_KEY=ark-your-seedream-key-here

# MySQL 数据库
KAIWU_DB_HOST=localhost
KAIWU_DB_PORT=3306
KAIWU_DB_USER=
KAIWU_DB_PASSWORD=
KAIWU_DB_NAME=kaiwu
KAIWU_DB_CHARSET=utf8mb4
